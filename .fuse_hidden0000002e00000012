<script>
const fmt=n=>'Rs. '+Math.round(n).toLocaleString('en-IN');
const fmt2=n=>'Rs. '+(Math.round(n*100)/100).toLocaleString('en-IN');
const r100=x=>Math.floor(Math.max(x,0)/100)*100;
function calc(){
  const t=parseFloat(document.getElementById('t').value);
  const p=[1,2,3,4].map(i=>parseFloat(document.getElementById('p'+i).value)||0);
  const ma=parseInt(document.getElementById('ma').value)||0;
  const mb=parseInt(document.getElementById('mb').value)||0;
  const out=document.getElementById('out');
  if(!t){out.innerHTML='<div class="callout warn" style="margin-top:16px">Enter the assessed tax.</div>';return;}
  const advPaid=p[3];
  // 234A
  const i234A=r100(t-advPaid)*0.01*ma;
  // 234B
  let i234B=0; if(advPaid < 0.9*t){ i234B=r100(t-advPaid)*0.01*mb; }
  // 234C
  const cond=[.12,.36,.75,1.0], base=[.15,.45,.75,1.0], mo=[3,3,3,1];
  let i234C=0; const cRows=[];
  for(let i=0;i<4;i++){
    let sf=0,intr=0;
    if(p[i] < t*cond[i]){ sf=r100(t*base[i]-p[i]); intr=sf*0.01*mo[i]; i234C+=intr; }
    cRows.push([['15 Jun','15 Sep','15 Dec','15 Mar'][i],(base[i]*100)+'%',fmt(sf),mo[i],fmt(intr)]);
  }
  const tot=i234A+i234B+i234C;
  const cbody=cRows.map(r=>`<tr><td>${r[0]}</td><td>${r[1]}</td><td>${r[2]}</td><td>${r[3]}</td><td>${r[4]}</td></tr>`).join('');
  out.innerHTML=`<div class="result" style="margin-top:18px"><div class="result-head">Total interest payable</div><div style="padding:18px">
    <div class="result-big">${fmt(tot)}</div>
    <div class="table-wrap" style="margin-top:14px"><table><tbody>
    <tr><td>Section 234A (late filing)</td><td>${fmt(i234A)}</td></tr>
    <tr><td>Section 234B (advance-tax shortfall)</td><td>${fmt(i234B)}</td></tr>
    <tr><td>Section 234C (instalment deferment)</td><td>${fmt(i234C)}</td></tr>
    <tr><td><b>Total interest</b></td><td><b>${fmt(tot)}</b></td></tr>
    </tbody></table></div>
    <div class="section-head" style="margin:22px 0 6px"><h2 style="font-size:15px">234C instalment break-up</h2></div>
    <div class="table-wrap"><table><thead><tr><th>Instalment</th><th>Target</th><th>Shortfall</th><th>Months</th><th>Interest</th></tr></thead><tbody>${cbody}</tbody></table></div>
    </div></div>`;
}
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',window.scrollY>30),{passive:true});
const ham=document.getElementById('hamburger'), mm=document.getElementById('mobileMenu');
ham.addEventListener('click',()=>mm.classList.toggle('show'));
mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>mm.class