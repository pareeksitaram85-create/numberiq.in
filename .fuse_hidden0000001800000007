<script>
const CATLBL={gst:"GST",it:"Income Tax",tds:"TDS",mca:"MCA"};
const MONTHS=["April 2026","May 2026","June 2026","July 2026","August 2026","September 2026","October 2026","November 2026","December 2026","January 2027","February 2027","March 2027"];
// month index 0=Apr2026 ... 11=Mar2027 ; mapping to real year/month
const YM=[[2026,4],[2026,5],[2026,6],[2026,7],[2026,8],[2026,9],[2026,10],[2026,11],[2026,12],[2027,1],[2027,2],[2027,3]];

// recurring monthly events (apply to every month)
const MONTHLY=[
  {day:7,  title:"TDS / TCS deposit for previous month (Challan 281)", cat:"tds"},
  {day:10, title:"GSTR-7 (TDS) & GSTR-8 (TCS) for previous month",    cat:"gst"},
  {day:11, title:"GSTR-1 (monthly filers) for previous month",       cat:"gst"},
  {day:13, title:"GSTR-6 (ISD) / GSTR-5 / IFF (QRMP) ",               cat:"gst"},
  {day:20, title:"GSTR-3B (monthly filers) for previous month",      cat:"gst"},
  {day:25, title:"PMT-06 advance tax (QRMP) ",                        cat:"gst"}
];

// one-off annual events  [monthIndex (0=Apr2026), day, title, cat]
const ONEOFF=[
  // TDS quarterly returns (24Q/26Q/27Q)
  [1,31,"TDS return Q4 FY 2025-26 (24Q/26Q/27Q)","tds"],
  [3,31,"TDS return Q1 FY 2026-27 (Apr-Jun)","tds"],
  [6,31,"TDS return Q2 FY 2026-27 (Jul-Sep)","tds"],
  [9,31,"TDS return Q3 FY 2026-27 (Oct-Dec)","tds"],
  [2,15,"Form 16 / 16A (salary & Q4) issuance — verify","tds"],
  // Advance tax (income tax)
  [2,15,"Advance tax 1st instalment (15%)","it"],
  [5,15,"Advance tax 2nd instalment (45%)","it"],
  [8,15,"Advance tax 3rd instalment (75%)","it"],
  [11,15,"Advance tax 4th instalment (100%)","it"],
  // Income-tax filing for FY 2025-26 (AY 2026-27), done during FY 2026-27
  [5,30,"Tax audit report (3CA/3CB-3CD) FY 2025-26","it"],
  [3,31,"ITR filing (non-audit) FY 2025-26","it"],
  [6,31,"ITR filing (audit cases) FY 2025-26","it"],
  [7,30,"ITR filing (transfer-pricing cases) FY 2025-26","it"],
  // GST annual
  [8,31,"GSTR-9 / GSTR-9C (FY 2025-26)","gst"],
  // MCA / company-law
  [1,30,"LLP Form 11 (Annual Return) FY 2025-26","mca"],
  [2,30,"DPT-3 (return of deposits)","mca"],
  [5,30,"DIR-3 KYC","mca"],
  [6,30,"LLP Form 8 (Statement of Account & Solvency)","mca"],
  [6,30,"MCA AOC-4 (approx. 30 days from AGM) — verify","mca"],
  [7,28,"MCA MGT-7 (approx. 60 days from AGM) — verify","mca"]
];

let active="all";
function build(){
  const events=[];
  MONTHS.forEach((m,mi)=>{
    MONTHLY.forEach(e=>events.push({mi,day:e.day,title:e.title,cat:e.cat}));
  });
  ONEOFF.forEach(([mi,day,title,cat])=>events.push({mi,day,title,cat}));
  return events;
}
const ALL=build();

function cats(){
  const el=document.getElementById('cats');
  const keys=["all","gst","it","tds","mca"];
  el.innerHTML=keys.map(k=>`<button class="cat ${k===active?'active':''}" data-k="${k}">${k==="all"?"All":CATLBL[k]}</button>`).join('');
  el.querySelectorAll('.cat').forEach(b=>b.onclick=()=>{active=b.dataset.k;cats();render();});
}
function render(){
  const cal=document.getElementById('cal');
  let html='';
  MONTHS.forEach((m,mi)=>{
    let evs=ALL.filter(e=>e.mi===mi && (active==='all'||e.cat===active)).sort((a,b)=>a.day-b.day);
    if(!evs.length) return;
    html+=`<div class="month-block"><div class="month-head"><span>${m}</span><span style="font-size:12px;color:var(--ink-dim)">${evs.length} deadline${evs.length>1?'s':''}</span></div>`;
    evs.forEach(e=>{html+=`<div class="ev"><span class="d">${e.day} ${m.split(' ')[0].slice(0,3)}</span><span class="t">${e.title}</span><span class="c ${e.cat}">${CATLBL[e.cat]}</span></div>`;});
    html+='</div>';
  });
  cal.innerHTML=html||'<div class="empty"><b>No deadlines</b>Clear the filter.</div>';
}
function pad(n){return String(n).padStart(2,'0');}
function exportICS(){
  let ics="BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//NumberIQ//Due Dates FY2026-27//EN\r\n";
  ALL.filter(e=>active==='all'||e.cat===active).forEach((e,i)=>{
    const [yr,mo]=YM[e.mi];
    const dt=`${yr}${pad(mo)}${pad(e.day)}`;
    ics+="BEGIN:VEVENT\r\n";
    ics+=`UID:numberiq-${e.mi}-${e.day}-${i}@numberiq.in\r\n`;
    ics+=`DTSTART;VALUE=DATE:${dt}\r\n`;
    ics+=`SUMMARY:[${CATLBL[e.cat]}] ${e.title}\r\n`;
    ics+="END:VEVENT\r\n";
  });
  ics+="END:VCALENDAR";
  const blob=new Blob([ics],{type:"text/calendar"});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download="numberiq-due-dates-fy2026-27.ics";a.click();
}
document.getElementById('ics').onclick=exportICS;
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',window.scrollY>30),{passive:true});
const ham=document.getElementById('hamburger'), mm=document.getElementById('mobileMenu');
ham.addEventListener('click',()=>mm.classList.toggle('show'));
