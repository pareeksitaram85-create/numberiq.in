<script>
const fmt=n=>'Rs. '+Math.round(n).toLocaleString('en-IN');
document.getElementById('rtype').addEventListener('change',e=>{
  document.getElementById('turnoverWrap').style.display = e.target.value==='nil' ? 'none':'block';
});
function calc(){
  const rtype=document.getElementById('rtype').value;
  const due=new Date(document.getElementById('due').value);
  const filed=new Date(document.getElementById('filed').value);
  const out=document.getElementById('out');
  if(isNaN(due)||isNaN(filed)){out.innerHTML='<div class="callout warn" style="margin-top:16px">Please enter both the due date and the filing date.</div>';return;}
  const days=Math.floor((filed-due)/86400000);
  if(days<=0){out.innerHTML='<div class="result" style="margin-top:16px"><div class="result-head">No late fee</div><div style="padding:18px">Return filed on or before the due date.</div></div>';return;}
  const perDay = rtype==='nil'?20:50;
  const cap = rtype==='nil'?500:parseInt(document.getElementById('turnover').value);
  const gross=days*perDay;
  const payable=Math.min(gross,cap);
  const half=payable/2;
  out.innerHTML=`<div class="result" style="margin-top:18px">
    <div class="result-head">Late fee payable</div>
    <div style="padding:18px">
      <div class="result-big">${fmt(payable)}</div>
      <div class="table-wrap" style="margin-top:14px"><table><tbody>
        <tr><td>Days delayed</td><td>${days} days</td></tr>
        <tr><td>Rate per day</td><td>${fmt(perDay)} (combined)</td></tr>
        <tr><td>Gross fee (days × rate)</td><td>${fmt(gross)}</td></tr>
        <tr><td>Maximum cap</td><td>${fmt(cap)}</td></tr>
        <tr><td><b>Late fee payable</b></td><td><b>${fmt(payable)}</b></td></tr>
        <tr><td>— CGST</td><td>${fmt(half)}</td></tr>
        <tr><td>— SGST/UTGST</td><td>${fmt(half)}</td></tr>
      </tbody></table></div>
    </div></div>`;
}
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',window.scrollY>30),{passive:true});
const ham=document.getElementById('hamburger'), mm=document.getElementById('mobileMenu');
ham.addEventListener('click',()=>mm.classList.toggle('show'));
mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>mm.classList.remove('show')));
</script>
