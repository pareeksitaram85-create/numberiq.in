<script>
const fmt=n=>'Rs. '+Math.round(n).toLocaleString('en-IN');
const fmt2=n=>'Rs. '+(Math.round(n*100)/100).toLocaleString('en-IN');
function monthsBetween(a,b){
  // count calendar months touched (part month = full month)
  let m=(b.getFullYear()-a.getFullYear())*12+(b.getMonth()-a.getMonth())+1;
  return m<1?0:m;
}
function calc(){
  const amt=parseFloat(document.getElementById('amt').value);
  const rate=parseFloat(document.getElementById('rate').value);
  const d1=new Date(document.getElementById('d1').value);
  const d2=new Date(document.getElementById('d2').value);
  const out=document.getElementById('out');
  if(!amt||isNaN(d1)||isNaN(d2)){out.innerHTML='<div class="callout warn" style="margin-top:16px">Enter the TDS amount and both dates.</div>';return;}
  if(d2<d1){out.innerHTML='<div class="callout warn" style="margin-top:16px">The "to" date must be on or after the "from" date.</div>';return;}
  const months=monthsBetween(d1,d2);
  const interest=amt*rate/100*months;
  out.innerHTML=`<div class="result" style="margin-top:18px"><div class="result-head">Interest payable</div><div style="padding:18px">
    <div class="result-big">${fmt(interest)}</div>
    <div class="table-wrap" style="margin-top:14px"><table><tbody>
    <tr><td>TDS amount</td><td>${fmt(amt)}</td></tr>
    <tr><td>Rate</td><td>${rate}% per month</td></tr>
    <tr><td>Months (part = full)</td><td>${months}</td></tr>
    <tr><td>Interest (TDS × Rate × Months)</td><td>${fmt(interest)}</td></tr>
    <tr><td><b>Total (TDS + interest)</b></td><td><b>${fmt(amt+interest)}</b></td></tr>
    </tbody></table></div></div></div>`;
}
